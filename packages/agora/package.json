{
  "name": "@mention/agora",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --reset-cache --clear",
    "dev": "expo start --reset-cache --tunnel --clear",
    "dev:local": "expo start --reset-cache --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "clean": "rm -rf dist .expo"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@livekit/react-native": "^2.9.6",
    "@livekit/react-native-expo-plugin": "^1.0.1",
    "@livekit/react-native-webrtc": "^137.0.3",
    "@mention/agora-shared": "*",
    "@oxyhq/bloom": "^0.8.6",
    "@oxyhq/core": "^3.7.1",
    "@oxyhq/services": "^10.5.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/query-async-storage-persister": "^5.100.0",
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@types/react-responsive": "^8.0.8",
    "axios": "^1.7.9",
    "expo": "^56.0.11",
    "expo-audio": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.18",
    "expo-font": "~56.0.6",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.17",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "livekit-client": "^2.19.2",
    "lottie-react-native": "^7.3.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "~0.21.0",
    "react-responsive": "^10.0.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "sonner-native": "^0.26.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
