{
  "name": "@mention/agora",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --reset-cache --clear",
    "dev": "expo start --reset-cache --tunnel --clear",
    "dev:local": "expo start --reset-cache --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "clean": "rm -rf dist .expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@livekit/react-native": "^2.9.6",
    "@livekit/react-native-expo-plugin": "^1.0.1",
    "@livekit/react-native-webrtc": "^137.0.2",
    "@mention/agora-shared": "*",
    "@oxyhq/core": "1.11.4",
    "@oxyhq/services": "6.9.12",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.90.6",
    "@types/react-responsive": "^8.0.8",
    "axios": "^1.7.9",
    "expo": "~55",
    "expo-audio": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.11",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "livekit-client": "^2.17.1",
    "lottie-react-native": "^7.3.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-responsive": "^10.0.1",
    "socket.io-client": "^4.8.1",
    "@oxyhq/bloom": "0.1.15",
    "sonner": "^2.0.7",
