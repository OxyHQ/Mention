# Mention frontend — environment variables
#
# Copy to `.env` for local development: `cp .env.example .env`
# Only `EXPO_PUBLIC_*` vars are exposed to the client bundle (Expo convention).
# No secret values belong here — these are public config / endpoints only.
# In production, NODE_ENV=production makes most URLs default to the live hosts,
# so the overrides below are primarily for local dev and previews.

# ── Backend API (Mention) ────────────────────────────────────────────
# REST + Socket.io base for the Mention backend.
# Prod default: https://api.mention.earth (wss://api.mention.earth for sockets).
EXPO_PUBLIC_API_URL=http://localhost:3000
# WebSocket URL for the Mention realtime backend (Socket.io).
API_URL_SOCKET=ws://localhost:3000
# Fallback socket URL used only if API_URL_SOCKET is unset (services/socketService.ts).
# EXPO_PUBLIC_BACKEND_URL=http://localhost:3000

# ── Chat / Oxy chat backend (optional) ───────────────────────────────
# Socket + base URL for the Oxy chat service. Prod default: wss://api.mention.earth.
# API_URL_SOCKET_CHAT=http://localhost:4000
# API_OXY_CHAT=http://localhost:4000

# ── Oxy platform (auth + API) ────────────────────────────────────────
# Oxy API base. Prod default: https://api.oxy.so
EXPO_PUBLIC_OXY_BASE_URL=http://localhost:3001

# ── Public web origin ────────────────────────────────────────────────
# Origin used to build shareable deep links (posts, trends, rooms).
# Default: https://mention.earth
# EXPO_PUBLIC_WEB_BASE_URL=https://mention.earth

# ── Build / runtime environment ──────────────────────────────────────
# Selects build variant in app.config.js: "testflight" | "production" (else dev).
# EXPO_PUBLIC_ENV=

# ── Logging (lib/logger) ─────────────────────────────────────────────
# Minimum log level: debug | info | log | warn | error
# EXPO_PUBLIC_LOG_LEVEL=info
# Comma-separated logger context filter for verbose debug output (empty = none).
# EXPO_PUBLIC_LOG_DEBUG=

# ── Third-party integrations ─────────────────────────────────────────
# KLIPY GIF/sticker API key (public app key — not a secret).
# EXPO_PUBLIC_KLIPY_APP_KEY=
# Stripe Payment Links (public hosted-checkout URLs, opened in browser).
# EXPO_PUBLIC_STRIPE_LINK_PLUS=
# EXPO_PUBLIC_STRIPE_LINK_FILE=

# ── Native build only (not used by the web/client bundle) ─────────────
# Path to the Firebase google-services.json for Android EAS builds.
# Default: ../../google-services.json
# GOOGLE_SERVICES_JSON=
