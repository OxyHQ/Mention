{
  "name": "@mention/frontend",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "start": "expo start --reset-cache --tunnel --clear",
    "start:local": "expo start --reset-cache --clear",
    "dev": "expo start --reset-cache --tunnel --clear",
    "dev:local": "expo start --reset-cache --clear",
    "reset-project": "bun ./scripts/reset-project.js",
    "clear-cache": "bun ./scripts/clear-cache.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist",
    "build:apk": "eas build --platform android --profile apk --local",
    "build:apk:cloud": "eas build --platform android --profile apk",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:preview": "eas build --platform android --profile preview",
    "test": "jest --watchAll=false",
    "typecheck": "node ./scripts/typecheck.mjs",
    "lint": "expo lint",
    "clean": "rm -rf dist .expo",
    "analyze-bundle": "bun ./scripts/analyze-bundle.js"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript",
        "eslint-config-expo"
