# =============================================================================
# Mention Backend — Environment Variables
# =============================================================================
# Copy to `.env` for local development and fill in real values.
# In AWS, provide the SECRET-marked vars via AWS Secrets Manager / SSM
# Parameter Store (SecureString) and inject them into the container. The
# non-secret vars can be plain task-definition / container environment values.
#
# Legend:
#   [SECRET]   — sensitive credential; store in a secrets manager, never commit.
#   [required] — the service needs this to function in production.
#   [optional] — has a safe default; override only when needed.
#
# NOTE ON AUTH/JWT: This backend does NOT use a local JWT secret. All token
# verification (HTTP and WebSocket) is delegated to the Oxy platform via the
# OXY_SERVICE_API_KEY / OXY_SERVICE_API_SECRET service credentials below. There
# is intentionally no JWT_SECRET to provision.
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=production                 # [required] "production" in AWS
PORT=3000                           # [optional] listen port (binds 0.0.0.0); default 3000
LOG_LEVEL=info                      # [optional] pino level: trace|debug|info|warn|error; default info (prod) / debug (dev)
FRONTEND_URL=                       # [required in prod] frontend origin for CORS (e.g. https://mention.earth)

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGODB_URI=                              # [SECRET][required] full connection string (may embed credentials)
MONGODB_MAX_POOL_SIZE=100                 # [optional]
MONGODB_MIN_POOL_SIZE=10                  # [optional]
MONGODB_MAX_IDLE_TIME_MS=60000            # [optional]
MONGODB_SOCKET_TIMEOUT_MS=45000           # [optional]
MONGODB_SERVER_SELECTION_TIMEOUT_MS=20000 # [optional]
MONGODB_HEARTBEAT_FREQUENCY_MS=10000      # [optional]
MONGODB_MAX_RETRIES=5                     # [optional]
MONGODB_READ_PREFERENCE=                  # [optional] e.g. primaryPreferred, secondaryPreferred

# -----------------------------------------------------------------------------
# Redis (used for cache + Socket.IO adapter for horizontal scaling)
# Provide REDIS_URL (preferred). If absent, the discrete REDIS_HOST/PORT/etc are used.
# -----------------------------------------------------------------------------
REDIS_URL=                          # [SECRET][required] e.g. rediss://:password@host:6379 (creds embedded -> secret)
# REDIS_URI=                        # [SECRET][optional] alias for REDIS_URL
# REDIS_HOST=localhost              # [optional] used only if REDIS_URL is not set
# REDIS_PORT=6379                   # [optional]
# REDIS_PASSWORD=                   # [SECRET][optional] used only with REDIS_HOST
# REDIS_DB=0                        # [optional]

# -----------------------------------------------------------------------------
# Oxy platform integration (AUTH lives here — see JWT note at top)
# -----------------------------------------------------------------------------
OXY_API_URL=https://api.oxy.so     # [required] Oxy API base URL
OXY_SERVICE_API_KEY=               # [SECRET][required] service DeveloperApp key (acquires/refreshes service JWTs)
OXY_SERVICE_API_SECRET=            # [SECRET][required] service DeveloperApp secret
# OXY_SERVICE_TOKEN=               # [SECRET][optional] pre-issued service token (alternative to key+secret)

# -----------------------------------------------------------------------------
# LiveKit (live audio/video rooms)
# -----------------------------------------------------------------------------
LIVEKIT_URL=                       # [required for rooms] e.g. wss://your-project.livekit.cloud
LIVEKIT_API_KEY=                   # [SECRET][required for rooms]
LIVEKIT_API_SECRET=                # [SECRET][required for rooms]

# -----------------------------------------------------------------------------
# Object storage — S3-compatible (DigitalOcean Spaces / AWS S3) for media
# The DO_SPACES_* names are S3-compatible; point them at AWS S3 if migrating.
# -----------------------------------------------------------------------------
DO_SPACES_KEY=                     # [SECRET][required for uploads] S3 access key id
DO_SPACES_SECRET=                  # [SECRET][required for uploads] S3 secret access key
DO_SPACES_REGION=ams3              # [required for uploads] e.g. us-east-1 on AWS
DO_SPACES_BUCKET=mention-bucket    # [required for uploads] bucket name
DO_SPACES_ENDPOINT=                # [optional] S3 endpoint; defaults to https://<region>.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=            # [optional] public CDN base URL for objects (e.g. https://cloud.mention.earth)

# -----------------------------------------------------------------------------
# Firebase Admin (push notifications)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=               # [required for push] Firebase project id
FIREBASE_SERVICE_ACCOUNT_BASE64=   # [SECRET][required for push] base64-encoded service-account JSON

# -----------------------------------------------------------------------------
# Federation (ActivityPub)
# -----------------------------------------------------------------------------
FEDERATION_ENABLED=true            # [optional] set "false" to disable federation; default enabled
FEDERATION_DOMAIN=                 # [required for federation] public domain serving actors (e.g. mention.earth)
ACTOR_DOMAIN=                      # [optional] actor domain; defaults to FEDERATION_DOMAIN
FEDERATION_BLOCKED_DOMAINS=        # [optional] comma-separated blocklist
FEDERATION_MAX_CONTENT_LENGTH=50000 # [optional]
FEDERATION_DELIVERY_RETRIES=5      # [optional]

# -----------------------------------------------------------------------------
# AI features (topic extraction, translation, summaries) — optional
# -----------------------------------------------------------------------------
ALIA_API_URL=https://api.alia.onl  # [optional] AI service base URL
ALIA_API_KEY=                      # [SECRET][optional] AI features disabled if unset

# Post classification (topics, sentiment, intent, quality/safety signals).
# Provider/model selection lives INSIDE Alia (never stored on the post), so there
# is no provider env var here. The service no-ops unless this is "true" AND
# ALIA_API_KEY is set.
POST_CLASSIFICATION_ENABLED=false  # [optional] set "true" to enable async post classification

# -----------------------------------------------------------------------------
# GIF search (Klipy) — optional
# -----------------------------------------------------------------------------
KLIPY_APP_KEY=                     # [SECRET][optional] enables GIF search

# -----------------------------------------------------------------------------
# Admin & misc tuning — optional
# -----------------------------------------------------------------------------
ADMIN_USER_IDS=                    # [optional] comma-separated Oxy user ids granted admin
MAX_PRECOMPUTE_USERS=500           # [optional] feed precompute fan-out cap

# Cache TTLs (seconds) — optional
CACHE_USER_TTL=300
CACHE_POST_TTL=120
CACHE_FEED_TTL=900
CACHE_FOLLOW_TTL=600

# Link-preview image processing — optional
LINK_PREVIEW_MAX_FILE_SIZE=
LINK_PREVIEW_MAX_WIDTH=
LINK_PREVIEW_MAX_HEIGHT=
LINK_PREVIEW_JPEG_QUALITY=
LINK_PREVIEW_PNG_QUALITY=
LINK_PREVIEW_WEBP_QUALITY=
