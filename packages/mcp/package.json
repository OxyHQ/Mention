{
  "name": "@mention/mcp",
  "version": "1.0.0",
  "description": "MCP server for Mention social platform",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "start": "bun server.ts",
    "start:http": "bun server-http.ts",
    "start:node": "node dist/server-http.js",
    "dev": "bun --watch server.ts",
    "dev:http": "bun --watch server-http.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.8.3"
  }
}
